<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trash Sub Category</title>
    <link rel="stylesheet" href="/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="/assets/css/style.css">
</head>

<body>
    <div class="container-scroller"> <%- include('sidebar') %>
            <div class="container-fluid page-body-wrapper"> <%- include('header') %>
                    <div class="main-panel">
                        <div class="content-wrapper">
                            <div class="card">
                                <div class="card-body">
                                    <h4 class="card-title"> Trash Sub Category </h4>
                                    <div class="table-responsive">
                                        <table class="table table-dark">
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>Category</th>
                                                    <th>Sub Category</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if(subCategory.length> 0){ %> <% subCategory.forEach((sub,index)=>{
                                                        %> <tr>
                                                            <td>
                                                                <%= index + 1 %>
                                                            </td>
                                                            <td>
                                                                <%= sub.categoryId ? sub.categoryId.categoryName
                                                                    : "No Category" %>
                                                            </td>
                                                            <td>
                                                                <%= sub.subCategoryName %>
                                                            </td>
                                                            <td> <a href="/subcategory/restore/<%= sub._id %>"
                                                                    class="btn btn-success btn-sm"> Restore </a> <a
                                                                    href="/subcategory/permanent-delete/<%= sub._id %>"
                                                                    class="btn btn-danger btn-sm"
                                                                    onclick="return confirm('Delete permanently?')">
                                                                    Delete Forever </a> </td>
                                                        </tr>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="4" class="text-center"> No Sub
                                                                        Categories Found In Trash </td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div> <%- include('footer') %>
                    </div>
            </div>
    </div>
    <script src="/assets/vendors/js/vendor.bundle.base.js"></script>
    <script src="/assets/js/off-canvas.js"></script>
    <script src="/assets/js/misc.js"></script>
</body>

</html>